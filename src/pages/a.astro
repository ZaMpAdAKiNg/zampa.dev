---
// /a (EN) — Variant A "The Quarterly". Thin wrapper: resolve content + the
// build-time GitHub signal, hand them to the language-agnostic component.
import VariantA from '../components/VariantA.astro';
import { useContent } from '../lib/i18n';
import { getGithubData } from '../lib/github';

export const prerender = false; // REQUIRED — activates ISR freshness for the GitHub signal (24h). Keep it.

const { lang, t } = useContent(Astro);
const githubData = await getGithubData();
---

<VariantA t={t} github={githubData} lang={lang} />
