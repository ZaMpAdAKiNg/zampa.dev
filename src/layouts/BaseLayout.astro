---
// BaseLayout — FOUNDATION-OWNED. Used ONLY by the /now and index (chooser)
// pages. It is deliberately neutral and sober so it never competes with the two
// visual variants, which each own their own layout. No shared styling with the
// variants; no remote fonts (self-contained, system stacks only).
import { switchLangHref, localizeHref } from '../lib/i18n';
import type { Lang } from '../data/content';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Label for the language toggle (the OTHER language, e.g. "PT"). */
  langLabel: string;
  langSwitchAria: string;
  skipLabel: string;
}

const { lang, title, description, langLabel, langSwitchAria, skipLabel } = Astro.props;
const currentPath = Astro.url.pathname;
const altHref = switchLangHref(currentPath, lang);
const homeHref = localizeHref('/', lang);
const nowHref = localizeHref('/now', lang);
const isNow = currentPath.replace(/\/$/, '').endsWith('/now') || currentPath.replace(/\/$/, '').endsWith('now');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%230d9488'/%3E%3Ctext x='16' y='23' font-family='monospace' font-size='20' font-weight='700' text-anchor='middle' fill='%23fafaf9'%3EZ%3C/text%3E%3C/svg%3E" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <a class="skip" href="#main">{skipLabel}</a>
    <div class="shell">
      <header class="site-head">
        <a class="brand" href={homeHref} aria-label="zampa.dev">
          <span class="brand-mark" aria-hidden="true">Z</span>
          <span class="brand-word">zampa<span class="brand-dot">.</span>dev</span>
        </a>
        <nav class="head-nav" aria-label={lang === 'pt' ? 'Navegação' : 'Navigation'}>
          <a href={nowHref} aria-current={isNow ? 'page' : undefined}>/now</a>
          <a class="lang" href={altHref} lang={lang === 'en' ? 'pt' : 'en'} aria-label={langSwitchAria}>{langLabel}</a>
        </nav>
      </header>

      <main id="main">
        <slot />
      </main>

      <footer class="site-foot">
        <span>© 2026 ZaMpA</span>
        <span class="foot-sep" aria-hidden="true">·</span>
        <a href={homeHref}>zampa.dev</a>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #fafaf9;
    --bg-elev: #ffffff;
    --fg: #16161a;
    --muted: #6b6b73;
    --faint: #9a9aa2;
    --border: #e6e6e1;
    --border-strong: #d3d3cc;
    --accent: #0d9488;
    --accent-soft: #0d948814;
    --ring: #0d948855;
    --radius: 12px;
    --font-sans: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    --font-mono: ui-monospace, 'SF Mono', 'JetBrains Mono', 'Menlo', 'Consolas', monospace;
    --maxw: 46rem;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0a0a0b;
      --bg-elev: #121214;
      --fg: #ededf0;
      --muted: #9a9aa4;
      --faint: #6a6a74;
      --border: #1e1e22;
      --border-strong: #2a2a30;
      --accent: #2dd4bf;
      --accent-soft: #2dd4bf14;
      --ring: #2dd4bf55;
    }
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    -webkit-text-size-adjust: 100%;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  a {
    color: inherit;
  }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 3px;
  }

  .skip {
    position: absolute;
    left: -999px;
    top: 0;
    background: var(--accent);
    color: var(--bg);
    padding: 0.6rem 1rem;
    border-radius: 0 0 var(--radius) 0;
    font: 600 0.85rem/1 var(--font-mono);
    z-index: 10;
  }
  .skip:focus {
    left: 0;
  }

  .shell {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 1.5rem;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .site-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.75rem 0 2.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 8px;
    background: var(--accent);
    color: var(--bg);
    font: 700 1rem/1 var(--font-mono);
  }
  .brand-word {
    font-size: 1rem;
  }
  .brand-dot {
    color: var(--accent);
  }

  .head-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font: 500 0.9rem/1 var(--font-mono);
  }
  .head-nav a {
    text-decoration: none;
    color: var(--muted);
    transition: color 0.15s ease;
  }
  .head-nav a:hover,
  .head-nav a[aria-current='page'] {
    color: var(--fg);
  }
  .head-nav .lang {
    padding: 0.3rem 0.55rem;
    border: 1px solid var(--border-strong);
    border-radius: 7px;
    color: var(--muted);
  }
  .head-nav .lang:hover {
    color: var(--fg);
    border-color: var(--accent);
  }

  main {
    flex: 1 0 auto;
    padding-bottom: 4rem;
  }

  .site-foot {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 2rem 0 2.5rem;
    border-top: 1px solid var(--border);
    color: var(--faint);
    font: 500 0.82rem/1 var(--font-mono);
  }
  .site-foot a {
    color: var(--muted);
    text-decoration: none;
  }
  .site-foot a:hover {
    color: var(--fg);
  }
  .foot-sep {
    color: var(--border-strong);
  }

  @media (max-width: 480px) {
    .site-head {
      padding: 1.25rem 0 2rem;
    }
  }
</style>
