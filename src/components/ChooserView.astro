---
// Index CHOOSER — FOUNDATION-OWNED, neutral. Links to both visual variants
// (/a and /b) so they stay visible side by side while we compare, plus /now.
// Deleting the loser later is trivial: remove its card + page. The variant
// pages 404 until the variant workers land — that is expected and fine.
//
// Chooser microcopy lives here (foundation-only, bilingual) — it is NOT part of
// the shared content contract because the variants don't consume it.
import BaseLayout from '../layouts/BaseLayout.astro';
import { useContent, localizeHref } from '../lib/i18n';

const { lang, t } = useContent(Astro);

const copy = {
  en: {
    kicker: 'zampa.dev · design review',
    title: 'Two directions.',
    sub: 'Same content, two visual treatments. Open each, compare, keep one.',
    variants: [
      {
        href: '/a',
        tag: 'Variant A',
        name: 'Editorial',
        desc: 'Refined, typographic, magazine-grade calm.',
      },
      {
        href: '/b',
        tag: 'Variant B',
        name: 'Crypto-terminal',
        desc: 'Dark-first, monospace metadata, a sparing neon accent.',
      },
    ],
    nowCard: { name: 'Now', desc: 'The living page — what I am focused on right now.' },
    foundationNote: 'Foundation build · shared content + build-time GitHub signal.',
  },
  pt: {
    kicker: 'zampa.dev · revisão de design',
    title: 'Duas direções.',
    sub: 'Mesmo conteúdo, dois tratamentos visuais. Abra cada um, compare, escolha um.',
    variants: [
      {
        href: '/a',
        tag: 'Variante A',
        name: 'Editorial',
        desc: 'Refinado, tipográfico, uma calma de revista.',
      },
      {
        href: '/b',
        tag: 'Variante B',
        name: 'Crypto-terminal',
        desc: 'Dark-first, metadados em mono, um acento neon parcimonioso.',
      },
    ],
    nowCard: { name: 'Agora', desc: 'A página viva — no que estou focado agora.' },
    foundationNote: 'Build de fundação · conteúdo compartilhado + sinal GitHub em build time.',
  },
} as const;

const c = copy[lang];
const nowHref = localizeHref('/now', lang);
---

<BaseLayout
  lang={lang}
  title={t.meta.title}
  description={t.meta.description}
  langLabel={t.nav.langLabel}
  langSwitchAria={t.nav.langSwitchAria}
  skipLabel={t.nav.skipToContent}
>
  <section class="chooser">
    <p class="kicker">{c.kicker}</p>
    <h1>{c.title}</h1>
    <p class="sub">{c.sub}</p>

    <div class="cards">
      {
        c.variants.map((v, i) => (
          <a class="card card--variant" href={localizeHref(v.href, lang)} style={`--i:${i}`}>
            <span class="card-tag">{v.tag}</span>
            <span class="card-name">{v.name}</span>
            <span class="card-desc">{v.desc}</span>
            <span class="card-go" aria-hidden="true">→</span>
          </a>
        ))
      }
      <a class="card card--now" href={nowHref} style="--i:2">
        <span class="card-tag">/now</span>
        <span class="card-name">{c.nowCard.name}</span>
        <span class="card-desc">{c.nowCard.desc}</span>
        <span class="card-go" aria-hidden="true">→</span>
      </a>
    </div>

    <p class="foundation-note">{c.foundationNote}</p>
  </section>
</BaseLayout>

<style>
  .chooser {
    padding-top: 1rem;
  }
  .kicker {
    margin: 0 0 1.25rem;
    font: 600 0.76rem/1 var(--font-mono);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
  }
  h1 {
    margin: 0 0 0.6rem;
    font-size: clamp(2.5rem, 8vw, 3.75rem);
    line-height: 1;
    letter-spacing: -0.035em;
    font-weight: 660;
  }
  .sub {
    margin: 0 0 2.5rem;
    max-width: 30rem;
    font-size: 1.1rem;
    color: var(--muted);
  }

  .cards {
    display: grid;
    gap: 0.85rem;
  }
  .card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-areas:
      'tag   .    go'
      'name  name go'
      'desc  desc go';
    align-items: center;
    gap: 0.15rem 1rem;
    padding: 1.3rem 1.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elev);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.18s ease,
      transform 0.18s ease,
      box-shadow 0.18s ease;
    animation: fade 0.5s ease both;
    animation-delay: calc(var(--i) * 80ms);
  }
  @keyframes fade {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .card {
      animation: none;
    }
  }
  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px -18px var(--accent);
  }
  .card-tag {
    grid-area: tag;
    font: 600 0.7rem/1 var(--font-mono);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .card-name {
    grid-area: name;
    font-size: 1.35rem;
    font-weight: 620;
    letter-spacing: -0.02em;
  }
  .card-desc {
    grid-area: desc;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .card-go {
    grid-area: go;
    font-size: 1.5rem;
    color: var(--faint);
    transition:
      transform 0.18s ease,
      color 0.18s ease;
  }
  .card:hover .card-go {
    color: var(--accent);
    transform: translateX(4px);
  }
  .card--now {
    background: transparent;
    border-style: dashed;
  }

  .foundation-note {
    margin: 2.5rem 0 0;
    font: 500 0.8rem/1.5 var(--font-mono);
    color: var(--faint);
  }
</style>
