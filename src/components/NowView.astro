---
// /now (EN) — FOUNDATION-OWNED, shared, neutral. Not a visual variant.
import BaseLayout from '../layouts/BaseLayout.astro';
import { useContent, localizeHref } from '../lib/i18n';

const { lang, t } = useContent(Astro);
const n = t.now;
---

<BaseLayout
  lang={lang}
  title={`${n.title} — ${t.meta.ogTitle}`}
  description={n.metaDescription}
  ogTitle={t.meta.ogTitle}
  langLabel={t.nav.langLabel}
  langSwitchAria={t.nav.langSwitchAria}
  skipLabel={t.nav.skipToContent}
>
  <article class="now">
    <header class="now-head">
      <p class="eyebrow"><span class="pulse" aria-hidden="true"></span>{n.updatedLabel} — {n.updatedDate}</p>
      <h1>{n.title}</h1>
      <p class="lede">{n.intro}</p>
      <p class="access-note">{n.accessNote}</p>
    </header>

    <div class="tiers">
      {
        n.tiers.map((tier) => (
          <section class:list={['tier', `tier--${tier.level}`]} aria-labelledby={`tier-${tier.level}`}>
            <div class="tier-head">
              <h2 id={`tier-${tier.level}`}>{tier.heading}</h2>
              <span class="level-chip">
                {tier.level === 'confidential' && (
                  <svg class="lock" viewBox="0 0 16 16" width="12" height="12" aria-hidden="true">
                    <path
                      fill="currentColor"
                      d="M8 1a3 3 0 0 0-3 3v2H4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-1V4a3 3 0 0 0-3-3Zm-1.5 5V4a1.5 1.5 0 0 1 3 0v2h-3Z"
                    />
                  </svg>
                )}
                {tier.level}
              </span>
            </div>
            <ul class="entries">
              {tier.entries.map((e) => (
                <li>
                  <span class="entry-label">{e.label}</span>
                  <span class="entry-text">{e.text}</span>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>

    <a class="back" href={localizeHref('/', lang)}>&larr; {n.backHome}</a>
  </article>
</BaseLayout>

<style>
  .now {
    animation: rise 0.5s ease both;
  }
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .now {
      animation: none;
    }
  }

  .now-head {
    margin-bottom: 2.75rem;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1rem;
    font: 600 0.78rem/1 var(--font-mono);
    letter-spacing: 0.02em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--ring);
    animation: pulse 2.4s ease-out infinite;
  }
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 var(--ring);
    }
    70% {
      box-shadow: 0 0 0 8px transparent;
    }
    100% {
      box-shadow: 0 0 0 0 transparent;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pulse {
      animation: none;
    }
  }

  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2.25rem, 6vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 640;
  }
  .lede {
    margin: 0 0 0.75rem;
    max-width: 34rem;
    font-size: 1.1rem;
    color: var(--muted);
  }
  .access-note {
    margin: 0;
    max-width: 34rem;
    font-size: 0.9rem;
    color: var(--faint);
  }

  .tiers {
    display: grid;
    gap: 1rem;
  }
  .tier {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem 1.5rem;
    background: var(--bg-elev);
  }
  .tier--premium {
    border-color: var(--border-strong);
    box-shadow: inset 3px 0 0 var(--accent);
  }
  .tier--confidential {
    background: transparent;
    border-style: dashed;
  }

  .tier-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .tier-head h2 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 620;
    letter-spacing: -0.01em;
  }
  .level-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.22rem 0.55rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font: 600 0.68rem/1 var(--font-mono);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .tier--confidential .level-chip {
    background: transparent;
    border: 1px solid var(--border-strong);
    color: var(--faint);
  }
  .lock {
    display: block;
  }

  .entries {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }
  .entries li {
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 0.75rem;
    align-items: baseline;
  }
  .entry-label {
    font: 600 0.72rem/1.4 var(--font-mono);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--faint);
    padding-top: 0.1rem;
  }
  .entry-text {
    color: var(--fg);
  }
  .tier--confidential .entry-text {
    color: var(--muted);
    font-style: italic;
  }

  .back {
    display: inline-block;
    margin-top: 2.5rem;
    font: 500 0.9rem/1 var(--font-mono);
    color: var(--muted);
    text-decoration: none;
  }
  .back:hover {
    color: var(--accent);
  }

  @media (max-width: 760px), (pointer: coarse) {
    .back {
      position: relative;
    }
    .back::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: max(100%, 44px);
      height: 44px;
      transform: translate(-50%, -50%);
    }
  }

  @media (max-width: 520px) {
    .entries li {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
  }
</style>
