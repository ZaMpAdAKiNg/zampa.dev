---
// =============================================================================
// VariantB — "Signal Instrument" (variant /b, /pt/b)
// -----------------------------------------------------------------------------
// A self-contained full-document component (own <html>/<head>/<body> — does NOT
// use BaseLayout). Language-agnostic: it renders whatever `t`/`lang`/`github`
// it is handed. All copy comes from the content contract (no hardcoded strings).
//
// Aesthetic: a refined data-ledger / instrument panel. The "terminal" here is a
// TYPOGRAPHIC & structural mood — monospaced instrumentation, line-numbered
// section indices, hairline tabular grids, live status readouts. No fake console
// chrome, no typing animation, no command-line gimmick. Restraint over gimmick.
// =============================================================================
import { switchLangHref, localizeHref } from '../lib/i18n';
import type { SiteContent, Lang } from '../data/content';
import type { GithubData } from '../lib/github';
import Seo from './Seo.astro';
import FooterNav from './FooterNav.astro';
import UmamiAnalytics from './UmamiAnalytics.astro';

interface Props {
  t: SiteContent;
  github: GithubData;
  lang: Lang;
}

const { t, github, lang } = Astro.props as Props;

const pathname = Astro.url.pathname;
const altHref = switchLangHref(pathname, lang);
const homeHref = localizeHref('/', lang);
const nowHref = localizeHref('/now', lang);

// Localize CTA hrefs uniformly — anchors (#…) and absolute URLs pass through.
const ctaPrimaryHref = localizeHref(t.hero.ctaPrimary.href, lang);
const ctaSecondaryHref = localizeHref(t.hero.ctaSecondary.href, lang);

// Section register — mono indices give the page its instrument-panel structure.
const nav = [
  { label: t.nav.work, href: '#work' },
  { label: t.nav.method, href: '#method' },
  { label: t.nav.now, href: nowHref },
  { label: t.nav.contact, href: '#contact' },
];

// Instrument readouts derived from the build-time GitHub signal. Authority is
// anchored on commits + time (the track-record line) — these are SUPPORT.
const yrs = github.accountAgeYears;
const readouts = [
  { key: 'age', value: yrs, decimals: Number.isInteger(yrs) ? 0 : 1, label: t.authority.yearsLabel },
  { key: 'repos', value: github.publicRepos, decimals: 0, label: t.authority.reposLabel },
  { key: 'events', value: github.recentEventCount, decimals: 0, label: t.authority.activeLabel },
];

// Human-readable "last active" from the ISO timestamp (fed to a live status LED).
function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  const d = new Date(iso);
  return d.toLocaleDateString(lang === 'pt' ? 'pt-BR' : 'en-US', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });
}
const lastActive = fmtDate(github.lastActiveAt);
const liveLabel = lang === 'pt' ? 'último push' : 'last push';
const cachedLabel = lang === 'pt' ? 'sinal em cache' : 'cached signal';
const idLabel = lang === 'pt' ? 'identidade' : 'identity';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <meta name="color-scheme" content="dark light" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%230d9488'/%3E%3Ctext x='16' y='23' font-family='monospace' font-size='20' font-weight='700' text-anchor='middle' fill='%23fafaf9'%3EZ%3C/text%3E%3C/svg%3E"
    />
    <Seo
      lang={lang}
      title={t.meta.title}
      description={t.meta.description}
      ogTitle={t.meta.ogTitle}
      pathname={pathname}
    />
    <UmamiAnalytics />
  </head>
  <body>
    <a class="skip" href="#main">{t.nav.skipToContent}</a>

    <div class="grid-lines" aria-hidden="true"></div>

    <header class="head" data-head>
      <div class="head-inner">
        <a class="brand" href={homeHref} aria-label="zampa.dev">
          <span class="brand-mark" aria-hidden="true">Z</span>
          <span class="brand-word">zampa<span class="dot">.</span>dev</span>
          <span class="brand-motto" aria-hidden="true">// {t.hero.motto}</span>
        </a>
        <nav class="nav" aria-label={lang === 'pt' ? 'Navegação principal' : 'Primary navigation'}>
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
          <a
            class="lang"
            href={altHref}
            lang={lang === 'en' ? 'pt' : 'en'}
            aria-label={t.nav.langSwitchAria}>{t.nav.langLabel}</a
          >
        </nav>
      </div>
    </header>

    <main id="main">
      <!-- ===================== HERO ===================== -->
      <section class="hero" aria-labelledby="hero-h">
        <div class="hero-main">
          <p class="kicker reveal">
            <span class="led" aria-hidden="true"></span>
            <span class="mono">{t.hero.motto}</span>
          </p>
          <h1 id="hero-h" class="headline">
            {
              t.hero.headline.map((line, i) => (
                <span class="hl-line">
                  <span class="hl-inner" style={`--d:${0.12 + i * 0.09}s`}>{line}</span>
                </span>
              ))
            }
          </h1>
          <p class="support reveal" style="--d:.42s">{t.hero.support}</p>
          <div class="cta-row reveal" style="--d:.54s">
            <a class="btn btn-primary" href={ctaPrimaryHref}>
              <span>{t.hero.ctaPrimary.label}</span>
              <span class="btn-arrow" aria-hidden="true">→</span>
            </a>
            <a class="btn btn-ghost" href={ctaSecondaryHref}>
              <span>{t.hero.ctaSecondary.label}</span>
            </a>
          </div>
        </div>

        <aside class="readout reveal" style="--d:.3s" aria-label={lang === 'pt' ? 'Sinal ao vivo' : 'Live signal'}>
          <div class="readout-head">
            <span class="mono tiny">{idLabel}</span>
            <a class="mono handle" href={github.profileUrl} target="_blank" rel="noopener noreferrer"
              >@{github.handle}</a
            >
          </div>
          <p class="readout-id">{t.hero.eyebrow}</p>
          <dl class="readout-stats">
            {
              readouts.map((r) => (
                <div class="stat">
                  <dd class="stat-num mono" data-count={r.value} data-decimals={r.decimals}>
                    {r.decimals ? r.value.toFixed(r.decimals) : r.value}
                  </dd>
                  <dt class="stat-lbl mono">{r.label}</dt>
                </div>
              ))
            }
          </dl>
          <div class="readout-live">
            <span class={`live-led ${github.degraded ? 'is-cached' : ''}`} aria-hidden="true"></span>
            <span class="mono tiny">{github.degraded ? cachedLabel : liveLabel}</span>
            <span class="mono tiny val">{lastActive}</span>
          </div>
        </aside>
      </section>

      <!-- ===================== AUTHORITY (01) ===================== -->
      <section class="band" id="signal" aria-labelledby="auth-h">
        <div class="sec-index reveal"><span class="mono">01</span><span class="rule"></span><span class="mono tag">{t.sections.signal}</span></div>
        <div class="auth">
          <h2 id="auth-h" class="sec-h reveal">{t.authority.heading}</h2>
          <p class="auth-lead reveal" style="--d:.08s">{t.authority.trackRecordLine}</p>
          <dl class="auth-grid">
            {
              readouts.map((r, i) => (
                <div class="auth-stat reveal" style={`--d:${0.14 + i * 0.08}s`}>
                  <dd class="auth-num mono" data-count={r.value} data-decimals={r.decimals}>
                    {r.decimals ? r.value.toFixed(r.decimals) : r.value}
                  </dd>
                  <dt class="auth-lbl mono">{r.label}</dt>
                </div>
              ))
            }
          </dl>
          <p class="fineprint mono reveal">
            {t.authority.note}
            {github.degraded && <span class="cached-flag"> · {cachedLabel}</span>}
          </p>
        </div>
      </section>

      <!-- ===================== WORK (02) ===================== -->
      <section class="band" id="work" aria-labelledby="work-h">
        <div class="sec-index reveal"><span class="mono">02</span><span class="rule"></span><span class="mono tag">{t.sections.work}</span></div>
        <h2 id="work-h" class="sec-h reveal">{t.work.heading}</h2>
        <p class="sec-intro reveal" style="--d:.06s">{t.work.intro}</p>
        <div class="work-list">
          {
            t.work.projects.map((p, i) => (
              <article class="proj reveal" style={`--d:${0.1 + i * 0.08}s`}>
                <div class="proj-idx mono">WORK.{String(i + 1).padStart(2, '0')}</div>
                <div class="proj-body">
                  <div class="proj-top">
                    <h3 class="proj-name">{p.name}</h3>
                    <span class="chip mono">{p.status}</span>
                  </div>
                  <p class="proj-tag">{p.tagline}</p>
                  <p class="proj-desc">{p.description}</p>
                  <div class="proj-foot">
                    <ul class="tags" aria-label={lang === 'pt' ? 'Tecnologias' : 'Tags'}>
                      {p.tags.map((tag) => (
                        <li class="mono">{tag}</li>
                      ))}
                    </ul>
                    <a class="proj-link mono" href={p.url} target="_blank" rel="noopener noreferrer">
                      {p.url.replace(/^https?:\/\//, '')}
                      <span class="btn-arrow" aria-hidden="true">↗</span>
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <!-- ===================== METHOD (03) ===================== -->
      <section class="band" id="method" aria-labelledby="method-h">
        <div class="sec-index reveal"><span class="mono">03</span><span class="rule"></span><span class="mono tag">{t.sections.method}</span></div>
        <div class="method">
          <div class="method-copy">
            <h2 id="method-h" class="sec-h reveal">{t.method.heading}</h2>
            {t.method.body.map((para, i) => <p class="method-para reveal" style={`--d:${0.06 + i * 0.06}s`}>{para}</p>)}
          </div>
          <ol class="method-points">
            {
              t.method.points.map((point, i) => (
                <li class="reveal" style={`--d:${0.1 + i * 0.06}s`}>
                  <span class="pt-idx mono">{String(i + 1).padStart(2, '0')}</span>
                  <span class="pt-text">{point}</span>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <!-- ===================== OSS (04) ===================== -->
      <section class="band" id="oss" aria-labelledby="oss-h">
        <div class="sec-index reveal"><span class="mono">04</span><span class="rule"></span><span class="mono tag">{t.sections.oss}</span></div>
        <h2 id="oss-h" class="sec-h reveal">{t.oss.heading}</h2>
        <p class="sec-intro reveal" style="--d:.06s">{t.oss.intro}</p>
        <ul class="oss-list">
          {
            t.oss.items.map((item, i) => (
              <li class="oss-row reveal" style={`--d:${0.08 + i * 0.06}s`}>
                <a class="oss-inner" href={item.url} target="_blank" rel="noopener noreferrer">
                  <span class="oss-name mono">
                    {item.name}
                    <span class="btn-arrow" aria-hidden="true">↗</span>
                  </span>
                  <span class="oss-desc">{item.description}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- ===================== BIO (05) ===================== -->
      <section class="band" id="bio" aria-labelledby="bio-h">
        <div class="sec-index reveal"><span class="mono">05</span><span class="rule"></span><span class="mono tag">{t.sections.bio}</span></div>
        <div class="bio">
          <h2 id="bio-h" class="sec-h reveal">{t.bio.heading}</h2>
          <div class="bio-body">
            {t.bio.body.map((para, i) => <p class="reveal" style={`--d:${0.06 + i * 0.07}s`}>{para}</p>)}
          </div>
        </div>
      </section>

      <!-- ===================== CONTACT (06) ===================== -->
      <section class="band contact" id="contact" aria-labelledby="contact-h">
        <div class="sec-index reveal"><span class="mono">06</span><span class="rule"></span><span class="mono tag">{t.sections.contact}</span></div>
        <h2 id="contact-h" class="sec-h reveal">{t.contact.heading}</h2>
        <p class="sec-intro reveal" style="--d:.06s">{t.contact.text}</p>
        <ul class="contact-list">
          {
            t.contact.links.map((link, i) => (
              <li class="reveal" style={`--d:${0.1 + i * 0.07}s`}>
                <a class="contact-link" href={link.href} target="_blank" rel="noopener noreferrer">
                  <span class="cl-label">{link.label}</span>
                  {link.handle && <span class="cl-handle mono">{link.handle}</span>}
                  <span class="btn-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>

    <footer class="foot">
      <div class="foot-inner">
        <span class="foot-tag mono">{t.footer.tagline}</span>
        <div class="foot-meta">
          <FooterNav lang={lang} links={t.footer.nav} ariaLabel={t.footer.navAriaLabel} />
          <span class="foot-sep" aria-hidden="true">·</span>
          <span class="mono">{t.footer.rights}</span>
        </div>
      </div>
    </footer>

    <style is:global>
      /* ---------------------------------------------------------------------
         Design tokens — dark-primary crypto-instrument palette. Light theme is
         a warm "paper ledger". Both intentional.
      --------------------------------------------------------------------- */
      :root {
        --bg: #f6f6f2;
        --bg-elev: #ffffff;
        --bg-sunk: #efefe9;
        --fg: #0c0c10;
        --fg-dim: #34343c;
        --muted: #5f5f68;
        --faint: #6a6a74; /* WCAG AA ≥4.5:1 on paper bg — GitHub signal must be crisp */
        --line: #e4e4dc;
        --line-strong: #d0d0c6;
        --accent: #0a746a;
        --accent-ink: #075f56;
        --accent-soft: #0a746a14;
        --warn: #8a5e10;
        --warn-soft: #8a5e1014;
        --ring: #0a746a66;
        --grid: rgba(12, 12, 16, 0.035);
        --glow: transparent;

        --sans: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        --mono: ui-monospace, 'SF Mono', 'JetBrains Mono', Menlo, 'Cascadia Code', Consolas, monospace;
        --maxw: 74rem;
        --pad: clamp(1.15rem, 4vw, 3rem);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #08080a;
          --bg-elev: #101015;
          --bg-sunk: #050507;
          --fg: #f1f1f4;
          --fg-dim: #c6c6ce;
          --muted: #8a8a95;
          --faint: #7c7c84; /* WCAG AA ≥4.5:1 on dark bg/elev — GitHub signal must be crisp */
          --line: #1b1b21;
          --line-strong: #2b2b34;
          --accent: #2dd4bf;
          --accent-ink: #5fe6d5;
          --accent-soft: #2dd4bf12;
          --warn: #e6bd57;
          --warn-soft: #e6bd5714;
          --ring: #2dd4bf66;
          --grid: rgba(255, 255, 255, 0.028);
          --glow: #2dd4bf14;
        }
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html {
        -webkit-text-size-adjust: 100%;
        scroll-behavior: smooth;
        scroll-padding-top: 5rem;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: var(--sans);
        font-size: clamp(15px, 0.95rem + 0.1vw, 16.5px);
        line-height: 1.62;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overflow-x: hidden;
      }
      /* Instrument glow behind the page in dark mode. */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background:
          radial-gradient(60rem 40rem at 82% -8%, var(--glow), transparent 60%),
          radial-gradient(50rem 34rem at -6% 12%, var(--glow), transparent 55%);
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      ::selection {
        background: var(--accent);
        color: var(--bg);
      }
      .mono {
        font-family: var(--mono);
        font-feature-settings: 'tnum' 1, 'zero' 1;
      }
      .tiny {
        font-size: 0.7rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 4px;
      }

      .skip {
        position: absolute;
        left: -999px;
        top: 0;
        z-index: 60;
        background: var(--accent);
        color: var(--bg);
        padding: 0.65rem 1.1rem;
        border-radius: 0 0 10px 0;
        font: 600 0.82rem/1 var(--mono);
      }
      .skip:focus {
        left: 0;
      }

      /* Faint tabular column lines — the "ledger grid" atmosphere. */
      .grid-lines {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 var(--pad);
        background-image: linear-gradient(
          to right,
          transparent 0,
          transparent calc(50% - 0.5px),
          var(--grid) calc(50% - 0.5px),
          var(--grid) calc(50% + 0.5px),
          transparent calc(50% + 0.5px)
        );
        opacity: 0.9;
      }

      main,
      .head,
      .foot {
        position: relative;
        z-index: 1;
      }

      /* ---------------------------------------------------------------------
         Header
      --------------------------------------------------------------------- */
      .head {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--bg) 72%, transparent);
        backdrop-filter: saturate(140%) blur(14px);
        -webkit-backdrop-filter: saturate(140%) blur(14px);
        border-bottom: 1px solid transparent;
        transition: border-color 0.25s ease, background 0.25s ease;
      }
      .head[data-scrolled] {
        border-bottom-color: var(--line);
        background: color-mix(in srgb, var(--bg) 88%, transparent);
      }
      .head-inner {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0.85rem var(--pad);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-weight: 650;
        letter-spacing: -0.01em;
      }
      .brand-mark {
        display: grid;
        place-items: center;
        width: 1.65rem;
        height: 1.65rem;
        border-radius: 7px;
        background: var(--accent);
        color: var(--bg);
        font: 700 0.9rem/1 var(--mono);
        box-shadow: 0 0 0 1px var(--accent-soft), 0 4px 14px -6px var(--ring);
      }
      .brand-word {
        font-size: 0.98rem;
      }
      .brand .dot {
        color: var(--accent);
      }
      .brand-motto {
        font: 500 0.72rem/1 var(--mono);
        color: var(--faint);
        letter-spacing: 0.02em;
        padding-left: 0.55rem;
        margin-left: 0.15rem;
        border-left: 1px solid var(--line-strong);
      }
      @media (max-width: 620px) {
        .brand-motto {
          display: none;
        }
      }
      @media (max-width: 340px) {
        .brand-word {
          display: none;
        }
      }
      .nav {
        display: flex;
        align-items: center;
        gap: clamp(0.7rem, 2.2vw, 1.6rem);
        font: 500 0.82rem/1 var(--mono);
      }
      .nav > a:not(.lang) {
        color: var(--muted);
        letter-spacing: 0.01em;
        position: relative;
        padding: 0.25rem 0;
        transition: color 0.16s ease;
      }
      .nav > a:not(.lang)::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: -2px;
        width: 100%;
        height: 1px;
        background: var(--accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.22s ease;
      }
      .nav > a:not(.lang):hover {
        color: var(--fg);
      }
      .nav > a:not(.lang):hover::after {
        transform: scaleX(1);
      }
      @media (max-width: 560px) {
        .nav > a:not(.lang):not([href='#work']):not([href^='/']) {
          display: none;
        }
      }
      .nav .lang {
        padding: 0.32rem 0.6rem;
        border: 1px solid var(--line-strong);
        border-radius: 7px;
        color: var(--muted);
        transition: color 0.16s ease, border-color 0.16s ease;
      }
      .nav .lang:hover {
        color: var(--fg);
        border-color: var(--accent);
      }

      @media (max-width: 760px), (pointer: coarse) {
        .brand,
        .nav > a {
          position: relative;
        }
        .brand::before,
        .nav > a::before {
          content: '';
          position: absolute;
          top: 50%;
          left: 50%;
          width: max(100%, 44px);
          height: 44px;
          transform: translate(-50%, -50%);
        }
        .nav > a:not(.lang) + a:not(.lang) {
          margin-left: 0.3rem;
        }
        .nav .lang {
          margin-left: calc(0.4rem + 2px);
        }
        .nav .lang::before {
          right: 0;
          left: auto;
          transform: translateY(-50%);
        }
      }

      /* ---------------------------------------------------------------------
         Layout scaffold
      --------------------------------------------------------------------- */
      .hero,
      .band {
        max-width: var(--maxw);
        margin: 0 auto;
        padding-left: var(--pad);
        padding-right: var(--pad);
      }
      .band {
        padding-top: clamp(3.5rem, 8vw, 7rem);
        padding-bottom: clamp(0.5rem, 2vw, 1rem);
        scroll-margin-top: 4.5rem;
      }

      .sec-index {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        margin-bottom: 1.6rem;
        color: var(--faint);
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }
      .sec-index .rule {
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, var(--line-strong), transparent);
      }
      .sec-index .tag {
        color: var(--accent);
        letter-spacing: 0.1em;
      }
      .sec-h {
        font-size: clamp(1.7rem, 3.4vw, 2.5rem);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.05;
        margin: 0 0 0.5rem;
      }
      .sec-intro {
        color: var(--muted);
        max-width: 44ch;
        margin: 0 0 2.2rem;
        font-size: 1.02rem;
      }

      /* ---------------------------------------------------------------------
         Hero
      --------------------------------------------------------------------- */
      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
        gap: clamp(1.6rem, 4vw, 3.6rem);
        align-items: start;
        padding-top: clamp(3rem, 9vw, 6.5rem);
        padding-bottom: clamp(3rem, 7vw, 5.5rem);
      }
      @media (max-width: 860px) {
        .hero {
          grid-template-columns: 1fr;
          gap: 2.4rem;
        }
      }
      .kicker {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        margin: 0 0 1.4rem;
        color: var(--accent);
        font-size: 0.8rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .led {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 0 var(--ring);
        animation: pulse 2.6s ease-out infinite;
      }
      @keyframes pulse {
        0% {
          box-shadow: 0 0 0 0 var(--ring);
        }
        70% {
          box-shadow: 0 0 0 7px transparent;
        }
        100% {
          box-shadow: 0 0 0 0 transparent;
        }
      }

      .headline {
        margin: 0 0 1.5rem;
        font-size: clamp(2.5rem, 6.4vw, 4.7rem);
        font-weight: 800;
        letter-spacing: -0.035em;
        line-height: 0.98;
      }
      .hl-line {
        display: block;
        overflow: hidden;
        padding-bottom: 0.12em;
        margin-bottom: -0.08em;
      }
      .hl-line:last-child .hl-inner {
        color: var(--accent);
      }
      .hl-inner {
        display: block;
        transform: translateY(calc(102% + 0.08em));
        animation: rise-line 0.86s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: var(--d, 0s);
      }
      @keyframes rise-line {
        to {
          transform: translateY(0);
        }
      }

      .support {
        margin: 0 0 2rem;
        max-width: 46ch;
        color: var(--fg-dim);
        font-size: clamp(1.02rem, 1.4vw, 1.16rem);
        line-height: 1.55;
      }
      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.72rem 1.25rem;
        border-radius: 9px;
        font-weight: 600;
        font-size: 0.94rem;
        border: 1px solid transparent;
        transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
      }
      .btn-arrow {
        transition: transform 0.2s ease;
      }
      .btn-primary {
        background: var(--accent);
        color: var(--bg);
        box-shadow: 0 8px 22px -12px var(--ring);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 28px -12px var(--ring);
      }
      .btn-primary:hover .btn-arrow {
        transform: translateX(4px);
      }
      .btn-ghost {
        color: var(--fg);
        border-color: var(--line-strong);
        background: var(--bg-elev);
      }
      .btn-ghost:hover {
        border-color: var(--accent);
        color: var(--accent-ink);
        transform: translateY(-2px);
      }

      /* Instrument readout panel */
      .readout {
        border: 1px solid var(--line);
        border-radius: 14px;
        background: linear-gradient(180deg, var(--bg-elev), color-mix(in srgb, var(--bg-elev) 88%, var(--bg-sunk)));
        padding: 1.15rem 1.2rem 1rem;
        box-shadow: 0 1px 0 var(--line) inset, 0 20px 40px -30px rgba(0, 0, 0, 0.5);
        position: relative;
      }
      .readout-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        padding-bottom: 0.85rem;
        border-bottom: 1px solid var(--line);
        color: var(--faint);
      }
      .readout-head .handle {
        color: var(--muted);
        font-size: 0.78rem;
        transition: color 0.16s ease;
      }
      .readout-head .handle:hover {
        color: var(--accent);
      }
      .readout-id {
        margin: 0.85rem 0 1rem;
        font-size: 0.92rem;
        color: var(--fg-dim);
        font-weight: 550;
      }
      .readout-stats {
        margin: 0;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.4rem;
        border-top: 1px dashed var(--line-strong);
        border-bottom: 1px dashed var(--line-strong);
        padding: 0.9rem 0;
      }
      .stat {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        min-width: 0;
      }
      .stat-num {
        font-size: clamp(1.3rem, 3vw, 1.7rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--fg);
        line-height: 1;
      }
      .stat-lbl {
        font-size: 0.7rem;
        line-height: 1.25;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--faint);
      }
      .readout-live {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding-top: 0.85rem;
        color: var(--muted);
      }
      .readout-live .val {
        margin-left: auto;
        color: var(--fg-dim);
        text-transform: none;
        letter-spacing: 0;
      }
      .live-led {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--accent);
        flex: none;
        box-shadow: 0 0 8px 1px var(--accent);
        animation: blink 2.2s steps(1, end) infinite;
      }
      .live-led.is-cached {
        background: var(--warn);
        box-shadow: 0 0 6px 0 var(--warn);
        animation: none;
      }
      @keyframes blink {
        0%,
        62% {
          opacity: 1;
        }
        70%,
        100% {
          opacity: 0.28;
        }
      }

      /* ---------------------------------------------------------------------
         Authority
      --------------------------------------------------------------------- */
      .auth-lead {
        font-size: clamp(1.35rem, 3.2vw, 2.05rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.24;
        max-width: 22ch;
        margin: 0 0 2.4rem;
        text-wrap: balance;
      }
      .auth-grid {
        margin: 0 0 1.6rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1px;
        background: var(--line);
        border: 1px solid var(--line);
        border-radius: 12px;
        overflow: hidden;
      }
      .auth-stat {
        background: var(--bg-elev);
        padding: 1.5rem 1.3rem;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }
      .auth-num {
        font-size: clamp(2rem, 5vw, 3.1rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1;
        color: var(--accent);
      }
      .auth-lbl {
        font-size: 0.72rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--muted);
      }
      @media (max-width: 620px) {
        .auth-grid {
          grid-template-columns: 1fr;
        }
      }
      .fineprint {
        color: var(--faint);
        font-size: 0.76rem;
        line-height: 1.5;
        max-width: 60ch;
        margin: 0;
      }
      .cached-flag {
        color: var(--warn);
      }

      /* ---------------------------------------------------------------------
         Work
      --------------------------------------------------------------------- */
      .work-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .proj {
        display: grid;
        grid-template-columns: 6.5rem 1fr;
        gap: 1.2rem;
        padding: 1.6rem;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: var(--bg-elev);
        position: relative;
        overflow: hidden;
        transition: border-color 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
      }
      .proj::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2px;
        background: var(--accent);
        transform: scaleY(0);
        transform-origin: top;
        transition: transform 0.28s ease;
      }
      .proj:hover {
        border-color: var(--line-strong);
        transform: translateY(-3px);
        box-shadow: 0 18px 40px -28px rgba(0, 0, 0, 0.55);
      }
      .proj:hover::before {
        transform: scaleY(1);
      }
      .proj-idx {
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        color: var(--faint);
        padding-top: 0.4rem;
      }
      @media (max-width: 620px) {
        .proj {
          grid-template-columns: 1fr;
          gap: 0.8rem;
          padding: 1.3rem;
        }
        .proj-idx {
          padding-top: 0;
        }
      }
      .proj-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-bottom: 0.5rem;
      }
      .proj-name {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      .chip {
        font-size: 0.68rem;
        letter-spacing: 0.03em;
        color: var(--accent-ink);
        background: var(--accent-soft);
        border: 1px solid color-mix(in srgb, var(--accent) 24%, transparent);
        padding: 0.28rem 0.6rem;
        border-radius: 999px;
        white-space: nowrap;
      }
      .proj-tag {
        margin: 0 0 0.65rem;
        color: var(--fg-dim);
        font-weight: 550;
        font-size: 1.02rem;
      }
      .proj-desc {
        margin: 0 0 1.15rem;
        color: var(--muted);
        font-size: 0.96rem;
        max-width: 60ch;
      }
      .proj-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.8rem;
      }
      .tags {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin: 0;
        padding: 0;
      }
      .tags li {
        font-size: 0.68rem;
        letter-spacing: 0.03em;
        color: var(--muted);
        border: 1px solid var(--line-strong);
        padding: 0.24rem 0.55rem;
        border-radius: 6px;
      }
      .proj-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.82rem;
        color: var(--muted);
        transition: color 0.16s ease;
      }
      .proj-link:hover {
        color: var(--accent);
      }
      .proj-link:hover .btn-arrow {
        transform: translate(2px, -2px);
      }

      @media (max-width: 760px), (pointer: coarse) {
        .handle,
        .proj-link {
          position: relative;
        }
        .handle::before,
        .proj-link::before {
          content: '';
          position: absolute;
          top: 50%;
          left: 50%;
          width: max(100%, 44px);
          height: 44px;
          transform: translate(-50%, -50%);
        }
      }

      /* ---------------------------------------------------------------------
         Method
      --------------------------------------------------------------------- */
      .method {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
        gap: clamp(1.5rem, 4vw, 3.5rem);
        align-items: start;
      }
      @media (max-width: 760px) {
        .method {
          grid-template-columns: 1fr;
          gap: 1.8rem;
        }
      }
      .method-para {
        color: var(--fg-dim);
        margin: 0 0 1rem;
        font-size: 1.03rem;
        max-width: 52ch;
      }
      .method-points {
        list-style: none;
        counter-reset: none;
        margin: 0.4rem 0 0;
        padding: 0;
        border-top: 1px solid var(--line);
      }
      .method-points li {
        display: grid;
        grid-template-columns: 2.4rem 1fr;
        gap: 0.8rem;
        align-items: start;
        padding: 1rem 0.2rem;
        border-bottom: 1px solid var(--line);
      }
      .pt-idx {
        color: var(--accent);
        font-size: 0.82rem;
        padding-top: 0.15rem;
        letter-spacing: 0.04em;
      }
      .pt-text {
        color: var(--fg-dim);
        font-weight: 500;
      }

      /* ---------------------------------------------------------------------
         OSS
      --------------------------------------------------------------------- */
      .oss-list {
        list-style: none;
        margin: 0;
        padding: 0;
        border-top: 1px solid var(--line);
      }
      .oss-row {
        border-bottom: 1px solid var(--line);
      }
      .oss-inner {
        display: grid;
        grid-template-columns: minmax(11rem, 0.8fr) minmax(0, 1.6fr);
        gap: 1rem 2rem;
        align-items: baseline;
        padding: 1.25rem 0.4rem;
        transition: padding-left 0.24s ease, background 0.2s ease;
      }
      @media (max-width: 640px) {
        .oss-inner {
          grid-template-columns: 1fr;
          gap: 0.4rem;
        }
      }
      .oss-row:hover .oss-inner {
        padding-left: 1rem;
        background: var(--accent-soft);
      }
      .oss-name {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.98rem;
        font-weight: 600;
        color: var(--fg);
      }
      .oss-row:hover .oss-name {
        color: var(--accent);
      }
      .oss-name .btn-arrow {
        color: var(--faint);
        transition: transform 0.2s ease, color 0.2s ease;
      }
      .oss-row:hover .oss-name .btn-arrow {
        color: var(--accent);
        transform: translate(2px, -2px);
      }
      .oss-desc {
        color: var(--muted);
        font-size: 0.94rem;
        line-height: 1.5;
      }

      /* ---------------------------------------------------------------------
         Bio
      --------------------------------------------------------------------- */
      .bio {
        display: grid;
        grid-template-columns: minmax(0, 0.5fr) minmax(0, 1fr);
        gap: clamp(1rem, 4vw, 3rem);
      }
      @media (max-width: 720px) {
        .bio {
          grid-template-columns: 1fr;
          gap: 1rem;
        }
      }
      .bio-body p {
        color: var(--fg-dim);
        margin: 0 0 1.1rem;
        font-size: 1.04rem;
        max-width: 58ch;
      }
      .bio-body p:last-child {
        margin-bottom: 0;
      }

      /* ---------------------------------------------------------------------
         Contact
      --------------------------------------------------------------------- */
      .contact-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.7rem;
        max-width: 40rem;
      }
      .contact-link {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 1.05rem 1.25rem;
        border: 1px solid var(--line);
        border-radius: 11px;
        background: var(--bg-elev);
        transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
      }
      .contact-link:hover {
        border-color: var(--accent);
        transform: translateX(4px);
        background: var(--accent-soft);
      }
      .cl-label {
        font-weight: 650;
        font-size: 1.02rem;
      }
      .cl-handle {
        color: var(--muted);
        font-size: 0.84rem;
      }
      .contact-link .btn-arrow {
        margin-left: auto;
        color: var(--faint);
        transition: transform 0.2s ease, color 0.2s ease;
      }
      .contact-link:hover .btn-arrow {
        color: var(--accent);
        transform: translateX(4px);
      }

      /* ---------------------------------------------------------------------
         Footer
      --------------------------------------------------------------------- */
      .foot {
        max-width: var(--maxw);
        margin: clamp(4rem, 9vw, 7rem) auto 0;
        padding: 2rem var(--pad) 2.6rem;
        border-top: 1px solid var(--line);
      }
      .foot-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.8rem;
      }
      .foot-tag {
        color: var(--fg-dim);
        font-size: 0.82rem;
        letter-spacing: 0.02em;
      }
      .foot-meta {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        color: var(--faint);
        font-size: 0.8rem;
      }
      .foot-meta a {
        color: var(--muted);
        transition: color 0.16s ease;
      }
      .foot-meta a:hover {
        color: var(--accent);
      }
      .foot-sep {
        color: var(--line-strong);
      }

      /* ---------------------------------------------------------------------
         Scroll reveal + motion. Default = hidden→revealed; reduced-motion and
         no-JS fall back to fully visible (see the .no-js / media guard).
      --------------------------------------------------------------------- */
      /* Default = fully VISIBLE. The hiding rule is gated behind [data-va-motion],
         which JS sets ONLY after confirming IntersectionObserver + no reduced
         motion. So without JS (or with reduced motion) the page renders complete —
         no blank screen. JS merely ADDS the scroll-in motion. */
      html[data-va-motion] .reveal {
        opacity: 0;
        transform: translateY(18px);
        transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        transition-delay: var(--d, 0s);
        will-change: opacity, transform;
      }
      html[data-va-motion] .reveal.is-visible {
        opacity: 1;
        transform: none;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        .reveal {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
        .hl-inner {
          animation: none !important;
          transform: none !important;
        }
        .led,
        .live-led {
          animation: none !important;
        }
        .btn,
        .proj,
        .contact-link,
        * {
          transition-duration: 0.001ms !important;
        }
      }
    </style>

    <script>
      // Progressive enhancement — the page is fully readable without this.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Header hairline appears once the page scrolls.
      const head = document.querySelector('[data-head]');
      const onScroll = () => {
        if (window.scrollY > 8) head?.setAttribute('data-scrolled', '');
        else head?.removeAttribute('data-scrolled');
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      const reveals = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
      const counters = Array.from(document.querySelectorAll<HTMLElement>('[data-count]'));

      // Count-up on the discrete GitHub integers (and the 1-decimal age).
      function animateCount(el: HTMLElement) {
        const target = parseFloat(el.dataset.count || '0');
        const decimals = parseInt(el.dataset.decimals || '0', 10);
        if (!isFinite(target)) return;
        const dur = 1100;
        const start = performance.now();
        const step = (now: number) => {
          const p = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          const val = target * eased;
          el.textContent = decimals ? val.toFixed(decimals) : String(Math.round(val));
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = decimals ? target.toFixed(decimals) : String(Math.round(target));
        };
        requestAnimationFrame(step);
      }

      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach((el) => el.classList.add('is-visible'));
      } else {
        // Only NOW do we opt into hiding-then-revealing — content was visible
        // by default, so no-JS / no-IO users always saw the full page.
        document.documentElement.setAttribute('data-va-motion', '');
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              el.classList.add('is-visible');
              if (el.hasAttribute('data-count')) animateCount(el);
              io.unobserve(el);
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.15 },
        );
        reveals.forEach((el) => io.observe(el));

        // Counters that are NOT themselves .reveal still get observed for count-up.
        const countIo = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              animateCount(entry.target as HTMLElement);
              countIo.unobserve(entry.target);
            });
          },
          { threshold: 0.5 },
        );
        counters.forEach((el) => {
          if (!el.classList.contains('reveal')) countIo.observe(el);
        });
      }
    </script>
  </body>
</html>
